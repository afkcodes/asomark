# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://asomark:asomark@localhost:5434/asomark

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── AI / LLM (set at least one) ──────────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Google Play Developer API ─────────────────────────
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_DEVELOPER_ID=

# ── App Store Connect API ─────────────────────────────
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_PRIVATE_KEY_PATH=

# ── Apple Search Ads ──────────────────────────────────
APPLE_SEARCH_ADS_CLIENT_ID=
APPLE_SEARCH_ADS_CLIENT_SECRET=

# ── Notifications ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ── Proxy (optional) ─────────────────────────────────
PROXY_URL=

# ── Server ────────────────────────────────────────────
BACKEND_PORT=3001
DASHBOARD_PORT=3000
NODE_ENV=development

# ── File Storage ──────────────────────────────────────
STORAGE_PATH=./storage
